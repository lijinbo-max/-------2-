# GLM-4-Flash API密钥
GLM4_API_KEY=your-api-key-here

# 数据库配置
# SQLite (默认，用于开发)
DATABASE_URL=sqlite:///job_helper.db

# MySQL (生产环境推荐)
# DATABASE_URL=mysql+pymysql://job_helper:password@localhost:3306/job_helper

# Redis缓存配置
REDIS_URL=redis://localhost:6379/0

# MinIO对象存储配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=job-helper
MINIO_SECURE=False

# 环境配置
ENVIRONMENT=development
DEBUG=True
